# Provider selection
# Docker Compose now fails fast when LLM_PROVIDER, TELEGRAM_BOT_TOKEN, or
# TELEGRAM_ALLOWED_CHAT_ID are empty for the bot service.
LLM_PROVIDER=none
BROKER_PROVIDER=none
MARKET_DATA_PROVIDER=yahoo
MARKET_INTELLIGENCE_PROVIDER=none
DISCLOSURE_PROVIDER=sec_edgar
COMMUNITY_PROVIDER=none
SEARCH_PROVIDER=none
# Legacy compatibility flags for Wave 1 provider selection.
YAHOO_ENABLED=true
ALPHA_VANTAGE_ENABLED=false
REDDIT_ENABLED=false
SEARXNG_ENABLED=false

# OpenAI / Azure OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL_DEFAULT=gpt-4o-mini
OPENAI_CHAT_MODEL_SMART=gpt-4.1
OPENAI_CHAT_MODEL_REASONING=o4-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIMENSIONS=

# LangSmith observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=t212ai-dev

AZURE_OPENAI_ENABLED=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBED_DEPLOYMENT=

# GenAI tool execution
GENAI_TOOL_CALL_LIMIT=8
GENAI_TOOL_CALL_TIMEOUT_SECONDS=30
GENAI_USE_RESPONSES_API=

# Trading 212
T212_ENVIRONMENT=demo
T212_DEMO_BASE_URL=https://demo.trading212.com/api/v0
T212_LIVE_BASE_URL=https://live.trading212.com/api/v0
T212_API_KEY=
T212_API_SECRET=
T212_LIVE_TRADING_ENABLED=false

# Alpaca
# Shared credentials for market-data now and broker support later.
ALPACA_ENVIRONMENT=paper
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_PAPER_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_TRADING_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_FEED=iex

# Telegram
TELEGRAM_BOT_TOKEN=
# Single chat id or comma-separated chat ids. The bot fails closed if this is empty.
TELEGRAM_ALLOWED_CHAT_ID=
# Optional single user id or comma-separated user ids. When set, only those users can interact.
TELEGRAM_ALLOWED_USER_ID=

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Reddit Data API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_REFRESH_TOKEN=
REDDIT_USER_AGENT=server:t212ai:v0.1.0 (by /u/your_reddit_username)
REDDIT_BASE_URL=https://oauth.reddit.com
REDDIT_AUTH_URL=https://www.reddit.com/api/v1/access_token

# Local persistence
GUIDELINE_MEMORY_PATH=data/guidelines/guidelines.json
DATABASE_URL=sqlite:///./data/t212ai.db

# Research/search tools
# Docker Compose bundles a local SearXNG instance on http://searxng:8080.
SEARXNG_BASE_URL=

# SEC EDGAR filing intelligence
# Optional override for SEC fair-access identification.
SEC_EDGAR_USER_AGENT=
SEC_EDGAR_SUBMISSIONS_BASE_URL=https://data.sec.gov/submissions
SEC_EDGAR_TICKERS_URL=https://www.sec.gov/files/company_tickers.json
